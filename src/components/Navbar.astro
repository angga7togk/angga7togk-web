---
import github from "../assets/github.svg";
import instagram from "../assets/instagram.svg";
import youtube from "../assets/youtube.svg";
import x from "../assets/x.svg";
import menu from "../assets/menu.svg";

const currentPage = Astro.url.pathname;

console.log(currentPage);

const list = [
  {
    title: "Hello",
    link: "/",
  },
  {
    title: "About",
    link: "/about",
  },
  {
    title: "Blog",
    link: "/blog",
  },
  {
    title: "Projects",
    link: "/projects",
  },
  {
    title: "Contact me",
    link: "/contact",
  },
];
---

<nav class="">
  <div class="head">
    <a href="/" class="">Angga7Togk</a>
    <p>Building web, mobile, and Minecraft server solutions since forever.</p>
  </div>

  <button class="nav-btn">
    <img src={menu.src} alt="" />
  </button>

  <div class="body">
    <div class="x-container">
      <button class="x-btn">
        <img src={x.src} alt="" />
      </button>
    </div>

    <ul>
      {
        list.map((item) => {
          const isActive = currentPage.split("/")[1] === item.link.split("/")[1];
          return (
            <li>
              <a href={item.link} class={`${isActive && 'active'}`}>{item.title}</a>
            </li>
          );
        })
      }
    </ul>

    <div class="bottom">
      <a href="https://github.com/angga7togk" target="_blank">
        <img src={github.src} alt="" srcset="" />
      </a>
      <a href="https://www.instagram.com/angga7togk/" target="_blank">
        <img src={instagram.src} alt="" srcset="" />
      </a>
      <a href="https://youtube.com/@angga7togk_" target="_blank">
        <img src={youtube.src} alt="" srcset="" />
      </a>
    </div>
  </div>
</nav>

<script>
  const navBtn = document.querySelector(".nav-btn");
  const navBody = document.querySelector(".body");
  const xBtn = document.querySelector(".x-btn");

  navBtn?.addEventListener("click", () => {
    navBody?.classList.toggle("on");
  });

  xBtn?.addEventListener("click", () => {
    navBody?.classList.toggle("on");
  });
</script>

<style>
  nav {
    z-index: 99999999;
    position: fixed;
    left: 0;
    top: 0;
    width: 30%;
    height: 100vh;
    background: #f3f3f3;
    display: flex;
    flex-direction: column;
  }

  nav .head {
    margin: 6rem 3rem 12px 3rem;
  }

  nav .head a {
    font-size: x-large;
    font-weight: 400;
  }

  nav .head p {
    margin: 0;
    margin-top: 10px;
    opacity: 0.5;
  }

  nav .nav-btn {
    display: none;
  }

  nav .nav-btn img {
    width: 100%;
    height: 100%;
  }

  nav .body {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  nav .body .x-container {
    display: none;
  }

  nav .body ul {
    margin: 3rem 3rem 12px 3rem;
    padding: 0;
    list-style: none;
  }

  nav .body ul li {
    margin: 0;
    padding: 12px 0;
  }

  nav .body ul li a {
    text-decoration: none;
    color: #000;
    transition: all 0.2s ease-in-out;
  }

  nav .body .bottom {
    margin: 3rem 3rem 2rem 3rem;
    padding: 0;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  nav .body .bottom a {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 48px;
    height: 48px;
    border-radius: 100%;
    background-color: #929292;
    transition: all 0.2s ease-in-out;
  }

  nav .body .bottom a img {
    width: 50%;
    height: 50%;
  }

  nav .body .bottom a:hover {
    background-color: #1a1a1a;
  }

  nav .body .bottom a:hover::after {
    opacity: 0;
  }

  @media (max-width: 768px) {
    nav {
      position: fixed;
      top: 0;
      left: 0;
      height: 4rem;
      width: 100%;
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      font-size: 90%;
    }

    nav .head {
      margin: 0 12px;
    }

    nav .head a {
      font-size: large;
    }

    nav .head p {
      display: none;
    }

    nav .nav-btn {
      margin: 0 12px;
      display: flex;
      justify-content: center;
      align-items: center;
      width: 32px;
      height: 32px;
      border: none;
      border-radius: 100%;
      background-color: #929292;
      transition: all 0.2s ease-in-out;
      cursor: pointer;
    }

    nav .nav-btn:hover {
      background-color: #1a1a1a;
    }

    nav .body {
      justify-content: start;
      position: fixed;
      right: 0;
      top: 0;
      height: 100vh;
      background: #f3f3f3;
      transition: all 0.2s ease-in-out;
      transform: translateX(100%);
    }

    nav .body.on {
      transform: translateX(0);
    }

    nav .body .x-container {
      display: flex;
      justify-content: flex-end;
      padding: 12px;
    }

    nav .body .x-container .x-btn {
      display: flex;
      justify-content: center;
      align-items: center;
      width: 32px;
      height: 32px;
      border: none;
      border-radius: 100%;
      background-color: #929292;
      transition: all 0.2s ease-in-out;
      cursor: pointer;
    }

    nav .body .x-container .x-btn:hover {
      background-color: #1a1a1a;
    }

    nav .body .x-container .x-btn img {
      width: 90%;
      height: 90%;
    }
  }
</style>
